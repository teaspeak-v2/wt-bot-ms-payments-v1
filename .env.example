APP_ENV=development
APP_NAME=wt-bot-ms-payments-v1
APP_VERSION=0.1.0
APP_BASE_URL=http://localhost:8080
APP_PUBLIC_BASE_URL=http://localhost:8080
APP_SWAGGER_URL=/swagger/doc.json
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APP_ENCRYPTION_KEY=change-me-to-a-32-byte-secret-key
SERVER_ADDR=:8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=15s
DATABASE_URL=postgres://wtbot:wtbot@localhost:5432/wtbot?sslmode=disable
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=1
DATABASE_MAX_CONN_LIFETIME=30m
DATABASE_MAX_CONN_IDLE_TIME=5m
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=10
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ISSUER=wt-bot-ms-users-v1
JWT_ACCESS_TTL=15m
SERVICE_API_KEY=change-me-to-a-long-random-service-key
